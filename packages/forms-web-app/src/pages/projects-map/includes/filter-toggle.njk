<div class="govuk-button-group govuk-!-margin-bottom-4">
	<form method="post" action="/projects-map" class="projects-map__filter-toggle__container">
		<input type="hidden" name="filterToggleValue" value="{{ showFilters }}"/>
		<button type="submit" class="govuk-button govuk-button--secondary projects-map__filter-toggle">
			{{ t('projectsMap.hideFilters' if showFilters else 'projectsMap.showFilters') }}
		</button>
	</form>
	<a href="{{ projectSearchURL }}{{ queryString }}" class="govuk-link">{{ t('projectsMap.switchToListView') }}</a>
</div>
