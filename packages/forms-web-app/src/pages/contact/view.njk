{% extends "layouts/default.njk" %}

{% set pageTitle = t('contact.heading1') %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">
        {{ t('contact.heading1') }}
      </h1>

      <h2 class="govuk-heading-m">
        {{ t('contact.heading2') }}
      </h2>

      <p class="govuk-body">
        {{ t('contact.paragraph1') }}
      </p>

      <p class="govuk-body">
        {{ t('contact.paragraph2', {
          link: '<a class="govuk-link" href="' + pinsContactDetails.contactUsFormURL + '">' + t('contact.paragraph2LinkText') + '</a>'
        }) | safe }}
      </p>

      <h2 class="govuk-heading-s">
        {{ t('contact.heading3') }}
      </h2>

      <p class="govuk-body">
        {{ t('contact.paragraph3') }} {{ pinsContactDetails.supportTeamPhoneNumber }}<br>
        {{ t('contact.paragraph4') }}
      </p>

      <p class="govuk-body">
        <a class="govuk-link" href="{{ govUK.callCharges }}">{{ t('contact.paragraph13LinkText') }}</a>
      </p>

      <h2 class="govuk-heading-s">
        {{ t('contact.paragraph10') }}
      </h2>

      <p class="govuk-body">
      <a class="govuk-link" href="mailto:{{ pinsContactDetails.enquiriesEmailAddress }}">
        {{ pinsContactDetails.enquiriesEmailAddress }}
      </a>
      </p>

      <h2 class="govuk-heading-s">
        {{ t('contact.heading4') }}
      </h2>

      <p class="govuk-body">
        Planning Inspectorate
        <br>
        c/o QUADIENT
        <br>
        69 Buckingham Avenue
        <br>
        Slough
        <br>
        SL1 4PN
        <br>
      </p>

      <h2 class="govuk-heading-s">
        {{ t('contact.heading5') }}
      </h2>

      <p class="govuk-body">
        {{ t('contact.paragraph7') }}
      </p>
      <p class="govuk-body">
        {{ t('contact.paragraph6') }}
        <a class="govuk-link" href="{{ pinsSocialMedia.twitterURL }}">{{ pinsSocialMedia.twitterHandle }}</a>
      </p>

      <p class="govuk-body">
        {{ t('contact.paragraph13', {
          link: '<a class="govuk-link" href="' + govUK.furtherInformationURL + '">' + t('contact.waysToContactLinkText') + '</a>'
        }) | safe }}
      </p>

      <h2 class="govuk-heading-m">
        {{ t('contact.heading6') }}
      </h2>

      <p class="govuk-body">
        {{ t('contact.paragraph8', {
          link: '<a class="govuk-link" href="' + govUK.complaintsProcedure + '">' + t('contact.paragraph8LinkText') + '</a>'
        }) | safe }}
      </p>

      <p class="govuk-body">
        {{ t('contact.howToComplainParagraph1', {
          link: '<a class="govuk-link" href="' + serviceFeedbackUrl + '">' + t('contact.howToComplainParagraph1LinkText') + '</a>'
        }) | safe }}
      </p>

      <h2 class="govuk-heading-m">
        {{ t('contact.heading7') }}
      </h2>

      <p class="govuk-body">
        {{ t('contact.paragraph9') }}
        {{ pinsContactDetails.pressAndMediaPhoneNumber }}
        <br>
        {{ t('contact.paragraph10') }}:
        <a class="govuk-link" href="mailto:{{ pinsContactDetails.pressAndMediaEmailAddress }}">{{ pinsContactDetails.pressAndMediaEmailAddress }}</a>
        <br>
        {{ t('contact.paragraph11') }}
        <br>
        {{ t('contact.paragraph12') }}
      </p>

      <p class="govuk-body">
        <a class="govuk-link" href="{{ govUK.callCharges }}">{{ t('contact.paragraph13LinkText') }}</a>
      </p>
    </div>
  </div>
{% endblock %}
