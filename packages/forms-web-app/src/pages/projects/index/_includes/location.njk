<h2 class="govuk-heading-m">
  {{ t('projectsIndex.projectLocation.heading1') }}
</h2>

{% if applicationData.projectLocation %}
  <p class="govuk-body" id="project-location">
    {{ applicationData.projectLocation }}
  </p>
{% endif %}

{% if mapAccessToken %}
  <div class="pins-map">
    <div class="pins-map__container">
      <div id="map" class="pins-map__content" role="region" aria-roledescription="map"
        {% if applicationData.projectLocation %}
          aria-labelledby="project-location"
        {% else %}
          aria-label="{{ t('projectsIndex.projectLocation.heading1') }}"
        {% endif %}
        data-token="{{ mapAccessToken }}"
        data-geojson="{{ mapGeoJSON | escape }}"
        data-zoom="{{ applicationData.mapZoomLevel }}"></div>
    </div>
  </div>
{% endif %}
